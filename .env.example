# 環境變數總覽見 .github/env-and-secrets.md
# API 專用說明見 apps/api/.env.example；Web 見 apps/web/.env.example
# K8s Secret 欄位見 infra/k8s/app-env.secret.example

# --- API（複製到 apps/api/.env）---
# 本機 Docker Postgres；雲端可改 Neon/Supabase/RDS 等 postgresql://…（常加 ?sslmode=require）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/safety?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_SEC=28800
PORT=3000

# --- Web（複製到 apps/web/.env.local）---
# 本機 API 3000、next dev 3001：
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Docker Compose / Nginx 同源：
# NEXT_PUBLIC_API_URL=http://localhost/api/v1
